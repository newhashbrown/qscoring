    "sitemap-tickers": "tsx scripts/build-sitemap-tickers.ts",
    "strong-picks": "tsx scripts/build-strong-picks.ts",
    "weekly-recap": "tsx scripts/build-weekly-recap.ts",
    "backfill-snapshots": "tsx scripts/backfill-snapshots.ts",
    "fundamentals": "tsx scripts/build-fundamentals.ts",
    "movers:backfill": "tsx scripts/build-movers.ts",
    "movers:dryrun": "tsx scripts/movers-dryrun.ts",
    "movers:backtest": "tsx scripts/movers-backtest.ts",
    "cross-check": "tsx scripts/cross-check-massive.ts",
    "research:export": "tsx scripts/research/export-factor-panel.ts",
    "research:lookahead": "tsx scripts/research/lookahead-check.ts",
    "test": "tsx --test lib/scoring/zscore.test.ts lib/market-date.test.ts lib/performance.test.ts lib/scoring/momentum-factor.test.ts lib/scoring/risk-factor.test.ts lib/movers-board.test.ts lib/scoring/company-header.test.ts lib/scoring/snapshot-header-compat.test.ts lib/scoring/fundamentals.test.ts lib/score-history.test.ts lib/scoring/universe.test.ts lib/scoring/percentile.test.ts lib/scoring/relative.test.ts lib/scoring/analyst.test.ts lib/scoring/quality.test.ts lib/scoring/risk-stats.test.ts lib/scoring/insider.test.ts"
