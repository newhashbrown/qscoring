    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.7",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "playwright": "^1.60.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wrangler": "^4.88.0"
  }
